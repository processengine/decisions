{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://processengine.dev/schemas/decisions/decision.schema.json",
  "title": "ProcessEngine decisions definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifacts"],
  "properties": {
    "artifacts": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "description", "when", "then"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "const": "decision-rule" },
              "description": { "type": "string", "minLength": 1 },
              "when": {
                "type": "object",
                "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
              },
              "then": {
                "type": "object",
                "additionalProperties": false,
                "required": ["decision", "reason"],
                "properties": {
                  "decision": { "type": "string", "minLength": 1 },
                  "reason": { "type": "string", "minLength": 1 },
                  "patchPlanFrom": { "type": "string", "minLength": 1 },
                  "metadata": { "type": "object" },
                  "tags": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "description", "version", "mode", "rules", "defaultDecision"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "const": "decision-set" },
              "description": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 },
              "mode": { "const": "first_match_wins" },
              "strict": { "type": "boolean" },
              "missingFactPolicy": { "enum": ["false", "error"] },
              "requiredFacts": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "rules": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "defaultDecision": {
                "type": "object",
                "additionalProperties": false,
                "required": ["decision", "reason"],
                "properties": {
                  "decision": { "type": "string", "minLength": 1 },
                  "reason": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        ]
      }
    }
  }
}
