{
  "name": "@processengine/decisions",
  "version": "1.0.0",
  "description": "Compile-first decision selection library for ProcessEngine.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "pack:check": "npm pack --dry-run",
    "smoke:pack": "node scripts/smoke-pack.mjs",
    "bench": "node benchmarks/run.mjs"
  },
  "keywords": [
    "processengine",
    "decisions",
    "decision-engine",
    "json",
    "dsl",
    "compile-first"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/processengine/decisions.git"
  },
  "bugs": {
    "url": "https://github.com/processengine/decisions/issues"
  },
  "homepage": "https://github.com/processengine/decisions#readme",
  "files": [
    "index.js",
    "index.d.ts",
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "COMPATIBILITY.md",
    "benchmarks/"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./schema": {
      "default": "./src/schema/decision.schema.json"
    }
  }
}
