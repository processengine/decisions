{
  "name": "@processengine/decisions",
  "version": "2.0.0",
  "description": "Flow 5 decision runtime for selecting outcomes from JSON-safe facts.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "engines": { "node": ">=20.19.0" },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:pack": "node scripts/smoke-pack.mjs",
    "release:check": "npm test && npm run test:pack && npm pack --dry-run",
    "prepublishOnly": "echo 'Publish only via GitHub Actions.' && exit 1",
    "version": "git add CHANGELOG.md package-lock.json package.json"
  },
  "keywords": ["processengine", "decisions", "decision-engine", "json", "dsl", "flow5"],
  "repository": { "type": "git", "url": "git+https://github.com/processengine/decisions.git" },
  "bugs": { "url": "https://github.com/processengine/decisions/issues" },
  "homepage": "https://github.com/processengine/decisions#readme",
  "files": ["index.js", "index.d.ts", "src/", "docs/", "examples/", "README.md", "LICENSE", "CHANGELOG.md", "COMPATIBILITY.md"],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "publishConfig": { "access": "public" }
}
