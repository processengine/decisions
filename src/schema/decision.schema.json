{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://processengine.dev/schema/decisions-v2.schema.json",
  "title": "@processengine/decisions v2 source artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["decisionSetId", "version", "title", "description", "cases", "default"],
  "properties": {
    "decisionSetId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    },
    "default": { "$ref": "#/$defs/then" },
    "metadata": { "$ref": "#/$defs/jsonObject" }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "when", "then"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "when": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/condition" }
        },
        "then": { "$ref": "#/$defs/then" },
        "metadata": { "$ref": "#/$defs/jsonObject" }
      }
    },
    "then": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome"],
      "properties": {
        "outcome": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" },
        "metadata": { "$ref": "#/$defs/jsonObject" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "condition": {
      "oneOf": [
        { "$ref": "#/$defs/jsonScalar" },
        { "type": "object", "minProperties": 1, "maxProperties": 1, "additionalProperties": false, "properties": {
          "eq": { "$ref": "#/$defs/jsonScalar" },
          "neq": { "$ref": "#/$defs/jsonScalar" },
          "gt": { "type": "number" },
          "gte": { "type": "number" },
          "lt": { "type": "number" },
          "lte": { "type": "number" },
          "in": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/jsonScalar" } },
          "notIn": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/jsonScalar" } },
          "exists": { "const": true },
          "missing": { "const": true },
          "eqFact": { "type": "string", "minLength": 1 },
          "neqFact": { "type": "string", "minLength": 1 },
          "gtFact": { "type": "string", "minLength": 1 },
          "gteFact": { "type": "string", "minLength": 1 },
          "ltFact": { "type": "string", "minLength": 1 },
          "lteFact": { "type": "string", "minLength": 1 }
        } }
      ]
    },
    "jsonScalar": { "type": ["string", "number", "boolean", "null"] },
    "jsonValue": {
      "oneOf": [
        { "$ref": "#/$defs/jsonScalar" },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        { "$ref": "#/$defs/jsonObject" }
      ]
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/jsonValue" }
    }
  }
}
